<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <title>Rever</title>
  <style>
    .container { 
        display: flex; 
        justify-content: center; 
        gap: 40px; 
        margin-top: 50px; 
    }

    h1 {
      margin-top: 150px;
    }

    img { 
        width: 250px; 
        border-radius: 10px; 
    }
    button { 
        margin-top: 10px; 
        padding: 10px; 
    }
  </style>
  <link rel="stylesheet" href="/main.css">
</head>
<body>
    <%- include('templates/nav') %>
    <h1>Hvilken rev er søtest?</h1>
  <div class="container">
    <div>
      <img class="image-rate" src="https://randomfox.ca/images/<%= fox1 %>.jpg">
        <form action="/vote" method="POST">
            <input type="hidden" name="foxId" value="<%= fox1 %>">
            <button>Velg denne</button>
        </form>
    </div>

    <div>
      <img src="https://randomfox.ca/images/<%= fox2 %>.jpg">
      <form action="/vote" method="POST">
        <input type="hidden" name="foxId" value="<%= fox2 %>">
        <button>Velg denne</button>
      </form>
    </div>
  </div>
  <% if (voted) { %>
  <p style="color: green; font-size: 22px; font-weight:bolder;">
    Du stemte på rev nr <%= voted %>
  </p>
<% } %>
</body>
</html>